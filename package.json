{
  "name": "partyparty",
  "version": "1.0.0",
  "description": "Get started by customizing your environment (defined in the .idx/dev.nix file) with the tools and IDE extensions you'll need for your project!",
  "main": "dist/index.ts",
  "scripts": {
    "start": "node dist/index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "cross-env DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres nodemon --exec ts-node index.ts",
    "migrate": "node-pg-migrate",
    "migrate:local": "cross-env DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres node-pg-migrate",
    "lint": "eslint --ext .js,.ts .",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start",
    "shell": "npm run build && firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@dataconnect/generated": "file:src/dataconnect-generated",
    "busboy": "^1.6.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.5",
    "googleapis": "^173.0.0",
    "node-pg-migrate": "^8.0.4",
    "nodemailer": "^8.0.10",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.16.0",
    "@types/sharp": "^0.31.1",
    "@typescript-eslint/eslint-plugin": "^5.12.0",
    "@typescript-eslint/parser": "^5.12.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.9.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.25.4",
    "firebase-functions-test": "^3.4.1",
    "firebase-tools": "^15.16.0",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
